# Airflow web login for local Docker Compose.
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# Project paths inside the Airflow Docker container.
PROJECT_ROOT=/opt/airflow/project
ENERGY_AIRFLOW_CONFIG=/opt/airflow/project/config/airflow_config.example.yaml
ENERGY_PLATFORM_CONFIG=/opt/airflow/project/config/local_config.example.yaml
ENERGY_PIPELINE_PYTHON=python

# SQL Server connection used by Airflow monitoring and quality checks.
# For Docker on Windows, host.docker.internal commonly points to the host machine.
SQLSERVER_HOST=host.docker.internal
SQLSERVER_DATABASE=EnergyWarehouse
SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server
SQLSERVER_TRUSTED_CONNECTION=false
SQLSERVER_USERNAME=
SQLSERVER_PASSWORD=
SQLSERVER_ENCRYPT=true
SQLSERVER_TRUST_SERVER_CERTIFICATE=true

# Airflow image/runtime options.
AIRFLOW_IMAGE_NAME=energy-airflow:local
AIRFLOW__CORE__LOAD_EXAMPLES=false

# Phase 4 Event Hubs Emulator / streaming settings.
ACCEPT_EULA=N
CONFIG_PATH=./Config.json
EVENTHUB_NAME=smart-meter-events
# Local emulator development connection string. Replace for a real namespace.
EVENTHUB_CONNECTION_STR=Endpoint=sb://localhost;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=SAS_KEY_VALUE;UseDevelopmentEmulator=true;
EVENTHUB_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
EVENTHUB_KAFKA_STARTING_OFFSETS=latest
STREAMING_DATA_LAKE_ROOT=./data_lake
STREAMING_CHECKPOINT_ROOT=./checkpoints
